                        bullets.append(pygame.Rect(player.centerx + 2, player.top - 15, 10, 24))
                        bullets.append(pygame.Rect(player.left - 15, player.top, 10, 24))
                        bullets.append(pygame.Rect(player.right + 5, player.top, 10, 24))
                    else:
                        bullets.append(pygame.Rect(player.centerx - 5, player.top, 10, 24))
                    shoot_cd = 10

                if (score - last_event_score) >= cfg["need_score"] and not boss and warn_timer == 0:
                    warn_timer, enemies, enemy_bullets = 120, [], []
                    
                     # 🔊 보스 등장 경고음
                    if warning_sound:
                        warning_sound.play()

                if warn_timer > 0:
                    warn_timer -= 1
                    if (warn_timer // 15) % 2 == 0:
                        tw = font_warning.render("WARNING!", True, RED)
