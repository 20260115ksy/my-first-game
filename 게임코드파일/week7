            for i, opt in enumerate(["NORMAL MODE", "HARDCORE MODE"]):
                c = WHITE if i == selected else (80, 80, 80)
                if i == selected and i == 1:
                    c = RED
                txt = font_mid.render(("> " if i == selected else "  ") + opt, True, c)
                screen.blit(txt, (WIDTH // 2 - txt.get_width() // 2, 380 + i * 90))

            desc_str = "4 Lives / Normal Speed" if selected == 0 else "3 Lives / Fast Speed & High Difficulty"
            desc_surf = font_small.render(desc_str, True, GREEN if selected == 0 else ORANGE)
            screen.blit(desc_surf, (WIDTH // 2 - desc_surf.get_width() // 2, 580))

            guide = font_small.render("Move: Arrow Keys  |  Fire: Space Bar  |  Exit: ESC", True, (180, 180, 180))
            screen.blit(guide, (WIDTH // 2 - guide.get_width() // 2, 650))

            pygame.display.flip()

            for e in pygame.event.get():
                if e.type == pygame.QUIT:
                    pygame.quit()
                    sys.exit()
                if e.type == pygame.KEYDOWN:
                    if e.key == pygame.K_ESCAPE:
                        pygame.quit()
                        sys.exit()
                    if e.key == pygame.K_UP:
                        selected = 0
                    if e.key == pygame.K_DOWN:
                        selected = 1
                    if e.key in [pygame.K_RETURN, pygame.K_SPACE]:
                        difficulty, menu = ("NORMAL" if selected == 0 else "HARD"), False
                        
                        # 🎵 기존 음악을 확실히 끄고 새 음악 틀기
                        pygame.mixer.music.stop() 
                        
                        try:
                            if difficulty == "HARD":
                                # 🚨 파일명이 다르면 아래 "hard.mp3"를 실제 파일명으로 꼭 바꿔주세요!
                                pygame.mixer.music.load("hard.mp3") 
                            else:
                                pygame.mixer.music.load("normal.mp3")
                            pygame.mixer.music.play(-1)
                        except Exception as err:
                            # 오류가 났다면 파이썬 터미널(검은 창)에 이유를 알려줍니다!
                            print(f"🚨 배경음악 변경 실패 원인: {err}")

            clock.tick(FPS)
            
        # 🛠️ 커진 화면에 맞춘 플레이어 시작 위치
        player = pygame.Rect(WIDTH // 2 - PLAYER_SIZE // 2, HEIGHT - PLAYER_SIZE - 30, PLAYER_SIZE, PLAYER_SIZE)
        bullets, enemy_bullets, enemies, explosions, items = [], [], [], [], []
        lives = 4 if difficulty == "NORMAL" else 3
        score, invincible, shoot_cd, current_lv_idx, last_event_score = 0, 0, 0, 0, 0
        power_timer = 0
        MAX_POWER_TIME = 300
        hue = 0
        shield_timer = 0
        MAX_SHIELD_TIME = 180
        boss, count_t, warn_timer, shake_timer = None, 180, 0, 0
        lvl_msg_timer, lvl_msg_text = 0, ""

        frame_index = 0
        frame_timer = 0

        running = True
        while running:
            dt = clock.tick(FPS)
            cfg = LEVELS[current_lv_idx]

            frame_timer += dt
            if frame_timer >= FRAME_DELAY:
                frame_index = (frame_index + 1) % len(walk_frames)
                frame_timer = 0

            spawn_rate = cfg["hard_spawn"] if difficulty == "HARD" else cfg["spawn"]
            spawn_count = cfg["hard_spawn_count"] if difficulty == "HARD" else 1
            boss_hp_value = cfg["boss_hp"] * 2 if difficulty == "HARD" else cfg["boss_hp"]

            ox, oy = (random.randint(-12, 12), random.randint(-12, 12)) if shake_timer > 0 else (0, 0)
            if shake_timer > 0:
                shake_timer -= 1

            # 🔴 올바른 배경 색칠
            if difficulty == "HARD":
                screen.fill((40, 10, 10))
            else:
                screen.fill(GRAY)

            # ⭐ 별 그리기 (for문 시작)
            for s in stars:
                
                # ── 💡 하드모드일 때 속도를 5배(s[2]*5)로 확실하게 증가! ──
                if difficulty == "HARD":
                    s[1] = (s[1] + (s[2] * 3.5)) % HEIGHT
                else:
                    s[1] = (s[1] + s[2]) % HEIGHT
                # ──────────────────────────────────────────────────
                    
                if difficulty == "HARD":
                    pygame.draw.circle(screen, (255, 80, 80), (s[0] + ox, s[1] + oy), s[2] + 2)
                    pygame.draw.circle(screen, WHITE, (s[0] + ox, s[1] + oy), s[2])
                else:
                    pygame.draw.circle(screen, WHITE, (s[0] + ox, s[1] + oy), s[2])
            # ⭐ 별 그리기 끝!
            # 🚨 이벤트 루프 (들여쓰기가 별 그리기 for문 밖으로 완전히 나와야 합니다!)
            for e in pygame.event.get():
                if e.type == pygame.QUIT:
                    pygame.quit()
                    sys.exit()
                if e.type == pygame.KEYDOWN:
                    if e.key == pygame.K_ESCAPE:
                        pygame.quit()
                        sys.exit()

            if count_t > 0:
                num = font_count.render(str(math.ceil(count_t / 60)), True, YELLOW)
                screen.blit(num, (WIDTH // 2 - num.get_width() // 2 + ox, HEIGHT // 2 - 120 + oy))
                count_t -= 1
            else:
                # 여기서부터 플레이어 이동 및 총알 발사 로직 시작
                keys = pygame.key.get_pressed()
                ms = 12 if difficulty == "NORMAL" else 15

                if keys[pygame.K_LEFT] and player.left > 0:
                    player.x -= ms
                if keys[pygame.K_RIGHT] and player.right < WIDTH:
                    player.x += ms
                if keys[pygame.K_UP] and player.top > 0:
                    player.y -= ms
                if keys[pygame.K_DOWN] and player.bottom < HEIGHT:
                    player.y += ms

                shoot_cd -= 1
                if keys[pygame.K_SPACE] and shoot_cd <= 0:
                    # ── 스페이스바로 총알 발사 및 사운드 재생 ──
                    if shoot_sound:
                        shoot_sound.play()
                        
                    # 🛠️ 플레이어 총알 크기도 굵직하게 키웠습니다.
