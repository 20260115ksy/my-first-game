def fire_phase_attack(boss, lv, player, enemy_bullets):
    bx, by = boss['rect'].centerx, boss['rect'].bottom

    if lv == 0:
        for px in [boss['rect'].left + 15, boss['rect'].right - 15]:
            for vx in [-4, 0, 4]:
                enemy_bullets.append({
                    "rect": pygame.Rect(px - 6, by, 12, 24),
                    "vx": vx, "vy": 10, "type": "bullet", "color": (255, 80, 0)
                })
    elif lv == 1:
        for angle_deg in range(0, 360, 45):
            rad = math.radians(angle_deg)
            speed = 7
            enemy_bullets.append({
                "rect": pygame.Rect(bx - 7, boss['rect'].centery - 7, 15, 15),
                "vx": math.cos(rad) * speed, "vy": math.sin(rad) * speed,
                "type": "bullet", "color": (255, 220, 50)
            })
    elif lv == 2:
        dx = player.centerx - bx
        dy = player.centery - by
        dist = math.hypot(dx, dy) or 1
        base_angle = math.atan2(dy, dx)
        for spread in [-0.25, 0, 0.25]:
            a = base_angle + spread
            speed = 12
            enemy_bullets.append({
                "rect": pygame.Rect(bx - 7, by, 15, 15),
                "vx": math.cos(a) * speed, "vy": math.sin(a) * speed,
                "type": "bullet", "color": (200, 0, 255)
            })


def draw_detailed_boss(surface, boss, lv, ox, oy, player_pos):
    bx, by = boss['rect'].x + ox, boss['rect'].y + oy
    bw, bh = boss['rect'].width, boss['rect'].height
    tick = pygame.time.get_ticks()
    phase_active = boss.get('phase_triggered', False)

    # 🛠️ 보스 디테일 그림들도 커진 보스 크기(180x150)에 맞게 비율 조정
    if lv == 0:
        pygame.draw.rect(surface, RED, (bx, by, bw, bh))
        border_col = (255, 255, 0) if phase_active else (100, 0, 0)
        pygame.draw.rect(surface, border_col, (bx, by, bw, bh), 4)
        pygame.draw.line(surface, YELLOW, (bx + bw // 2 - 22, by + 45), (bx + bw // 2 + 22, by + 45), 6)
        pygame.draw.line(surface, YELLOW, (bx + bw // 2 - 15, by + 60), (bx + bw // 2 + 15, by + 60), 6)
        pygame.draw.circle(surface, GREEN, (bx + 37, by + 67), 12)
        pygame.draw.circle(surface, BLUE, (bx + bw - 37, by + 67), 12)
        pygame.draw.rect(surface, BLACK, (bx + bw // 2 - 15, by + 7, 30, 22))
        flame_c = ORANGE if tick % 200 < 100 else RED
        pygame.draw.polygon(surface, flame_c, [(bx + 15, by), (bx - 15, by - 22), (bx + 30, by)])
        pygame.draw.polygon(surface, flame_c, [(bx + bw - 15, by), (bx + bw + 15, by - 22), (bx + bw - 30, by)])

    elif lv == 1:
        pygame.draw.rect(surface, (200, 180, 0), (bx, by, bw, bh), border_radius=15)
        border_col = (255, 80, 0) if phase_active else BLACK
        pygame.draw.rect(surface, border_col, (bx, by, bw, bh), 4, border_radius=15)
        for i in range(3):
            pygame.draw.line(surface, BLACK, (bx + i * 45 + 45, by + 15), (bx + i * 45 + 45, by + bh - 15), 3)
        core_c = CYAN if (boss['rect'].x % 10 < 5) else WHITE
        pygame.draw.circle(surface, core_c, (bx + bw // 2, by + bh // 2), 37)
        pygame.draw.circle(surface, BLACK, (bx + bw // 2, by + bh // 2), 37, 6)
        pygame.draw.rect(surface, GRAY, (bx + 15, by + bh - 7, 30, 30))
        pygame.draw.rect(surface, GRAY, (bx + bw - 45, by + bh - 7, 30, 30))

    elif lv == 2:
        pts = [
            (bx + bw // 2, by), (bx + 15, by + 45), (bx, by + bh // 2),
            (bx + bw // 2, by + bh), (bx + bw, by + bh // 2), (bx + bw - 15, by + 45)
        ]
        pygame.draw.polygon(surface, (30, 30, 50), pts)
        border_col = (255, 50, 255) if phase_active else PURPLE
        pygame.draw.polygon(surface, border_col, pts, 4)

        eye_center = (bx + bw // 2, by + bh // 2)
        pygame.draw.circle(surface, WHITE, eye_center, 30)
        pygame.draw.circle(surface, BLACK, eye_center, 30, 3)

        dx = player_pos[0] - eye_center[0]
        dy = player_pos[1] - eye_center[1]
        dist = math.hypot(dx, dy) or 1
        px, py = eye_center[0] + (dx / dist) * 12, eye_center[1] + (dy / dist) * 12
        eye_col = (255, 0, 200) if phase_active else (100, 0, 100)
        pygame.draw.circle(surface, eye_col, (int(px), int(py)), 15)
        pygame.draw.circle(surface, (0, 0, 0), (int(px), int(py)), 7)
        pygame.draw.circle(surface, border_col, eye_center, 60 + (tick % 500) // 15, 2)


def draw_item_shape(surface, x, y, item_type):
    # 🛠️ 아이템 크기 확대 (30x30 기준)
    if item_type == "heal":
        pygame.draw.rect(surface, GREEN, (x + 12, y, 6, 30))
        pygame.draw.rect(surface, GREEN, (x, y + 12, 30, 6))
    elif item_type == "shield":
        pts = [(x + 15, y), (x + 30, y + 10), (x + 25, y + 30), (x + 5, y + 30), (x, y + 10)]
        pygame.draw.polygon(surface, CYAN, pts)
        pygame.draw.polygon(surface, WHITE, pts, 2)
    elif item_type == "power":
        pygame.draw.circle(surface, YELLOW, (x + 15, y + 15), 15)
        p_txt = font_small.render("P", True, (0, 0, 0))
        surface.blit(p_txt, (x + 7, y - 3))


# 🛠️ [수정됨] Enter 키를 눌러야 넘어가는 수동 엔딩 화면 함수
def show_ending_screen(main_text, sub_text, color):
    e_stars = [[random.randint(0, WIDTH), random.randint(0, HEIGHT), random.randint(1, 3)] for _ in range(70)]
    waiting = True

    while waiting:
        screen.fill(GRAY)
        for s in e_stars:
            s[1] = (s[1] + s[2]) % HEIGHT
            pygame.draw.circle(screen, WHITE, (s[0], s[1]), s[2])

        m_surf = font_big.render(main_text, True, color)
        screen.blit(m_surf, (WIDTH // 2 - m_surf.get_width() // 2, HEIGHT // 2 - 120))

        s_surf = font_mid.render(sub_text, True, WHITE)
        screen.blit(s_surf, (WIDTH // 2 - s_surf.get_width() // 2, HEIGHT // 2 + 20))

        # 0.5초마다 깜빡이는 Enter 안내 문구
        if (pygame.time.get_ticks() // 500) % 2 == 0:
            c_surf = font_mid.render("Press ENTER to Return to Lobby", True, YELLOW)
            screen.blit(c_surf, (WIDTH // 2 - c_surf.get_width() // 2, HEIGHT // 2 + 150))

        pygame.display.flip()
        clock.tick(FPS)

        for e in pygame.event.get():
            if e.type == pygame.QUIT:
                pygame.quit()
                sys.exit()
            if e.type == pygame.KEYDOWN:
                if e.key in [pygame.K_RETURN, pygame.K_KP_ENTER]:
                    waiting = False


def main():
    while True:
        pygame.mixer.music.stop()
        try:
            pygame.mixer.music.load("normal.mp3")
            pygame.mixer.music.set_volume(0.3)
            pygame.mixer.music.play(-1)
        except Exception as e:
