        stars = [[random.randint(0, WIDTH), random.randint(0, HEIGHT), random.randint(1, 3)] for _ in range(100)]
        selected, menu = 0, True

        while menu:
            screen.fill(GRAY)
            for s in stars:
                s[1] = (s[1] + s[2]) % HEIGHT
                pygame.draw.circle(screen, WHITE, (s[0], s[1]), s[2])

