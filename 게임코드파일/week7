                                for ang in [-3, 0, 3]:
                                    enemy_bullets.append({
                                        "rect": pygame.Rect(boss['rect'].centerx - 7, boss['rect'].bottom, 15, 15),
                                        "vx": ang, "vy": 7, "type": "bullet", "color": YELLOW
                                    })
                        elif current_lv_idx == 2:
                            dx, dy = player.centerx - boss['rect'].centerx, player.centery - boss['rect'].bottom
                            dist = math.hypot(dx, dy) or 1
                            enemy_bullets.append({
                                "rect": pygame.Rect(boss['rect'].centerx - 7, boss['rect'].bottom, 15, 15),
                                "vx": (dx / dist) * 12, "vy": (dy / dist) * 12,
                                "type": "bullet", "color": PURPLE
                            })

                    if difficulty == "HARD" and boss['phase_triggered']:
                        phase_delays = [90, 80, 70]
                        boss['phase_shoot_tick'] += 1
                        if boss['phase_shoot_tick'] > phase_delays[current_lv_idx]:
                            boss['phase_shoot_tick'] = 0
                            fire_phase_attack(boss, current_lv_idx, player, enemy_bullets)

                    # 🛠️ 보스 체력바 크기 확대
                    hp_color = (255, 80, 0) if boss.get('phase_triggered') else RED
                    pygame.draw.rect(screen, (60, 0, 0), (WIDTH // 2 - 300 + ox, 70 + oy, 600, 25))
                    pygame.draw.rect(screen, hp_color, (WIDTH // 2 - 300 + ox, 70 + oy, int(600 * (boss['hp'] / boss['max_hp'])), 25))
                    bn = font_small.render(BOSS_NAMES[current_lv_idx], True, WHITE)
                    screen.blit(bn, (WIDTH // 2 - bn.get_width() // 2 + ox, 30 + oy))

                    if boss.get('phase_triggered'):
                        p2_lbl = font_small.render("◆ PHASE 2 ◆", True, (255, 140, 0))
                        screen.blit(p2_lbl, (WIDTH // 2 - p2_lbl.get_width() // 2 + ox, 100 + oy))

                elif warn_timer == 0:
                    if random.randint(1, spawn_rate) == 1:
                        for _ in range(spawn_count):
                            ecolor, hp, espd = cfg["enemy_color"], 1, cfg["speed"]
                            if current_lv_idx == 1:
                                if random.random() < 0.6:
                                    hp = 3
                                else:
                                    ecolor = RED
                                    espd = 7.5
                            # 🛠️ 일반 적 크기 확대 (36x36 -> 50x50)
                            enemies.append({
                                "rect": pygame.Rect(random.randint(50, WIDTH - 90), -60, 50, 50),
                                "hp": hp, "max_hp": hp, "color": ecolor, "speed": espd
                            })

                for it in items[:]:
                    it['rect'].y += it.get('vy', 6)
                    draw_item_shape(screen, it['rect'].x + ox, it['rect'].y + oy, it['type'])
                    if player.colliderect(it['rect']):
                        if it['type'] == "heal":
                            lives = min(5, lives + 1)
                        elif it['type'] == "shield":
                            shield_timer = MAX_SHIELD_TIME
                        elif it['type'] == "power":
                            power_timer = min(MAX_POWER_TIME, power_timer + 300)
                        score += 50
                        items.remove(it)
                    elif it['rect'].top > HEIGHT:
                        items.remove(it)

                for eb in enemy_bullets[:]:
                    eb['rect'].x += eb['vx']
                    eb['rect'].y += eb['vy']
                    pygame.draw.ellipse(screen, eb.get("color", ORANGE), (eb['rect'].x + ox, eb['rect'].y + oy, eb['rect'].width, eb['rect'].height))
                    if player.colliderect(eb['rect']):
                        if invincible <= 0 and shield_timer <= 0:
                            lives -= 1
                            invincible = 90
                            power_timer = 0
                            enemy_bullets.remove(eb)
                            if lives <= 0:
                                # 🛠️ [수정됨] 호출 함수 변경
                                show_ending_screen("GAME OVER", f"SCORE: {score}", RED)
                                running = False
                        elif shield_timer > 0:
                            enemy_bullets.remove(eb)
                    elif eb['rect'].top > HEIGHT or eb['rect'].bottom < 0 or eb['rect'].right < 0 or eb['rect'].left > WIDTH:
                        enemy_bullets.remove(eb)

                for b in bullets[:]:
                    b.y -= 18 # 🛠️ 총알 속도 증가
                    pygame.draw.rect(screen, YELLOW if power_timer <= 0 else CYAN, (b.x + ox, b.y + oy, b.width, b.height))
                    hit = False
                    for en in enemies[:]:
                        if b.colliderect(en['rect']):
                            en['hp'] -= 1
                            if en['hp'] <= 0:
                                for _ in range(5):
                                    explosions.append({
                                        "pos": [en['rect'].centerx, en['rect'].centery],
                                        "r": random.randint(7, 22), "life": 15, "c": en['color']
                                    })
                                if en['color'] in [YELLOW, PURPLE] and random.random() < 0.65:
                                    items.append({
                                        "rect": pygame.Rect(en['rect'].x + 10, en['rect'].y + 10, 30, 30),
                                        "type": "power"
                                    })
                                enemies.remove(en)
                                score += 10
                            hit = True
                            break

                    if not hit and boss and b.colliderect(boss['rect']):
                        boss['hp'] -= 1
                        hit = True
                        if boss['hp'] <= 0:
                     
                            #보스 폭발 효과음
                            if explosion_sound:
                                explosion_sound.play()
                        
                            shake_timer = 60
                            for _ in range(40):
                                explosions.append({
                                    "pos": [boss['rect'].centerx + random.randint(-90, 90), boss['rect'].centery + random.randint(-60, 60)],
                                    "r": random.randint(15, 75), "life": 40, "c": ORANGE
                                })
                            score += 1000
                            enemy_bullets = []
                            if current_lv_idx == len(LEVELS) - 1:
                                # 🛠️ [수정됨] 호출 함수 변경
                                show_ending_screen("MISSION CLEAR!", f"SCORE: {score}", GREEN)
                                running = False
                            else:
                                current_lv_idx += 1
                                lvl_msg_text = f"STAGE {current_lv_idx + 1}"
                                lvl_msg_timer = 120
                                boss = None
                                last_event_score = score

                    if hit or b.bottom < 0:
                        bullets.remove(b)

                for en in enemies[:]:
                    en['rect'].y += en['speed']
                    if en['color'] == PURPLE:
                        if en['rect'].centerx < player.centerx:
                            en['rect'].x += 4
                        elif en['rect'].centerx > player.centerx:
                            en['rect'].x -= 4

                    pygame.draw.polygon(
                        screen, en['color'],
                        [
                            (en['rect'].centerx + ox, en['rect'].bottom + oy),
                            (en['rect'].left + ox, en['rect'].top + oy),
                            (en['rect'].right + ox, en['rect'].top + oy)
                        ]
                    )

                    if en['max_hp'] > 1:
                        pygame.draw.rect(screen, RED, (en['rect'].x, en['rect'].y - 12, 50, 6))
                        pygame.draw.rect(screen, GREEN, (en['rect'].x, en['rect'].y - 12, 50 * (en['hp'] / en['max_hp']), 6))

                    if player.colliderect(en['rect']):
                        if invincible <= 0 and shield_timer <= 0:
                            lives -= 1
                            invincible = 90
                            power_timer = 0
                            enemies.remove(en)
                            if lives <= 0:
                                # 🛠️ [수정됨] 호출 함수 변경
                                show_ending_screen("GAME OVER", f"SCORE: {score}", RED)
                                running = False
                        else:
                            enemies.remove(en)
                    elif en['rect'].top > HEIGHT:
                        enemies.remove(en)

            if shield_timer > 0:
                # 🛠️ 쉴드 원 크기도 커진 플레이어에 맞게 확대
                pygame.draw.circle(screen, CYAN, (player.centerx + ox, player.centery + oy), 65, 3)
                shield_timer -= 1

            p_color = BLUE
            if power_timer > 0:
                hue = (hue + 0.02) % 1.0
                rgb = colorsys.hsv_to_rgb(hue, 1, 1)
                p_color = (int(rgb[0] * 255), int(rgb[1] * 255), int(rgb[2] * 255))
                pygame.draw.rect(screen, GRAY, (WIDTH // 2 - 75, 80, 150, 8))
                pygame.draw.rect(screen, p_color, (WIDTH // 2 - 75, 80, 150 * (power_timer / MAX_POWER_TIME), 8))
                power_timer -= 1

            for ex in explosions[:]:
                pygame.draw.circle(screen, ex['c'], (ex['pos'][0] + ox, ex['pos'][1] + oy), int(ex['r']))
                ex['life'] -= 1
                ex['r'] += 0.4
                if ex['life'] <= 0:
                    explosions.remove(ex)

            if (invincible // 10) % 2 == 0:
                screen.blit(walk_frames[frame_index], (player.x + ox, player.y + oy))
                
            if invincible > 0:
                invincible -= 1

            if lvl_msg_timer > 0:
                ms = font_big.render(lvl_msg_text, True, YELLOW)
                ms.set_alpha(min(255, lvl_msg_timer * 5))
                screen.blit(ms, (WIDTH // 2 - ms.get_width() // 2 + ox, HEIGHT // 2 - 60 + oy))
                lvl_msg_timer -= 1

            screen.blit(font_small.render(f"SCORE: {score}", True, WHITE), (30, 30))
            screen.blit(font_small.render(f"LIVES: {'♥' * lives}", True, RED), (WIDTH - 220, 30))

            if not boss and warn_timer == 0:
                pygame.draw.rect(screen, WHITE, (WIDTH // 2 - 150 + ox, 45 + oy, 300, 12), 1)
                pygame.draw.rect(screen, BLUE, (WIDTH // 2 - 150 + ox, 45 + oy, 300 * min(1.0, (score - last_event_score) / cfg["need_score"]), 12))
                lbl = font_small.render(cfg["label"], True, YELLOW)
                screen.blit(lbl, (WIDTH // 2 - lbl.get_width() // 2 + ox, 10 + oy))

            pygame.display.flip()

if __name__ == "__main__":
    main()

