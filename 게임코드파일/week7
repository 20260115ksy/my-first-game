                    if difficulty == "HARD" and not boss['phase_triggered']:
                        ratio = boss['hp'] / boss['max_hp']
                        if ratio <= PHASE_HP_RATIO[current_lv_idx]:
                            boss['phase_triggered'] = True
                            shake_timer = 30
                            lvl_msg_text = "PHASE 2!"
                            lvl_msg_timer = 90

                    if current_lv_idx == 2:
                        boss['move_tick'] += 1
