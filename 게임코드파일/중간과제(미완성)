            else:
                boss_call_current_text = b_full_text
        else:
            boss_call_char_index = len(b_full_text)
            boss_call_current_text = b_full_text

    # --- 실시간 오디오 제어 ---
    if state == "STORY":
        if 9 <= story_index <= 11: target_bgm_volume = 0.0  
        else: target_bgm_volume = bgm_volume  
            
        curr_vol = pygame.mixer.music.get_volume()
        if curr_vol > target_bgm_volume: pygame.mixer.music.set_volume(max(target_bgm_volume, curr_vol - 0.008))
        elif curr_vol < target_bgm_volume: pygame.mixer.music.set_volume(min(target_bgm_volume, curr_vol + 0.008))

        if story_index == 11 and not celular_played:
            if celular_sound: celular_sound.play()
            celular_played = True
        elif story_index != 11: celular_played = False 
    else:
        target_bgm_volume = bgm_volume

    # --- 인게임 플레이 업데이트 로직 ---
    if state in ["PLAY", "COUNTER_POV"]:
        keys = pygame.key.get_pressed()
        dx, dy = 0, 0
        is_moving = False

        if state == "PLAY":
            if keys[pygame.K_LEFT] or keys[pygame.K_a]: dx = -player_speed; current_dir = "LEFT"; is_moving = True
            elif keys[pygame.K_RIGHT] or keys[pygame.K_d]: dx = player_speed; current_dir = "RIGHT"; is_moving = True
