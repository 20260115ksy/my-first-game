    triangle_points = [
        (center_x - t_w // 2, triangle_pos_y),
        (center_x + t_w // 2, triangle_pos_y),
        (center_x, triangle_pos_y + t_h)
    ]

    pygame.draw.polygon(screen, YELLOW, triangle_points)
    pygame.draw.polygon(
        screen,
        WHITE,
        triangle_points,
        max(1, int(2 * scale_factor))
