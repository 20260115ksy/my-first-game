                screen.blit(pygame.transform.scale(counter_img, (int(390 * (WIDTH / BASE_WIDTH)), int(180 * (HEIGHT / BASE_HEIGHT)))), (int(420 * (WIDTH / BASE_WIDTH)), int(680 * (HEIGHT / BASE_HEIGHT))))

        # 어두운 반투명 오버레이
        overlay = pygame.Surface((WIDTH, HEIGHT))
        overlay.fill((0,0,0))
        overlay.set_alpha(160)
        screen.blit(overlay, (0,0))

        # 종이 이미지 및 닫기 버튼 배치
        if notice_image:
            notice_rect.center = (WIDTH // 2, HEIGHT // 2)
            screen.blit(notice_image, notice_rect)

            notice_x_button.width = int(50 * scale_factor)
            notice_x_button.height = int(50 * scale_factor)
            notice_x_button.topright = (notice_rect.right - int(20 * scale_factor), notice_rect.top + int(20 * scale_factor))
        else:
            notice_rect.center = (WIDTH // 2, HEIGHT // 2)
            pygame.draw.rect(screen, WHITE, notice_rect)
            draw_text_center("주의사항 이미지 없음", dialog_font, RED, notice_rect.centerx, notice_rect.centery)

        # X 버튼 출력
        pygame.draw.rect(screen, (180,50,50), notice_x_button)
        pygame.draw.rect(screen, WHITE, notice_x_button, max(1, int(2 * scale_factor)))
        draw_text_center("X", dialog_font, WHITE, notice_x_button.centerx, notice_x_button.centery)

    # --- 🌟 [추가 상태] 사장 호출 대화 상자 (단말기 튜토리얼) ---
    elif state == "CALL_BOSS":
        if ingame_bg_image:
            screen.blit(
                pygame.transform.scale(ingame_bg_image, (WIDTH, HEIGHT)),
                (0, 0)
        )
        if 'PATH_COUNTER_OVERLAY' in globals() and os.path.exists(PATH_COUNTER_OVERLAY):
            counter_img = pygame.image.load(PATH_COUNTER_OVERLAY).convert_alpha()
            screen.blit(pygame.transform.scale(counter_img, (int(390 * (WIDTH / BASE_WIDTH)), int(180 * (HEIGHT / BASE_HEIGHT)))), (int(420 * (WIDTH / BASE_WIDTH)), int(680 * (HEIGHT / BASE_HEIGHT))))

        overlay = pygame.Surface((WIDTH, HEIGHT))
        overlay.fill((0, 0, 0))
        overlay.set_alpha(100)
        screen.blit(overlay, (0, 0))

        # 하단 대화창UI 상자 그리기
        dialog_h, dialog_w = int(160 * scale_factor), int(1000 * scale_factor)
        dialog_x, dialog_y = (WIDTH - dialog_w) // 2, HEIGHT - dialog_h - int(30 * scale_factor)

        dialog_surf = pygame.Surface((dialog_w, dialog_h), pygame.SRCALPHA)
        dialog_surf.fill(DIALOG_BOX_COLOR)
        pygame.draw.rect(dialog_surf, WHITE, (0, 0, dialog_w, dialog_h), int(3 * scale_factor), border_radius=8)
        screen.blit(dialog_surf, (dialog_x, dialog_y))

        if boss_call_index < len(boss_call_script):
            b_speaker, b_full_text = boss_call_script[boss_call_index]
            
            # 화자 이름 출력
            screen.blit(name_font.render(b_speaker, True, YELLOW if "사장" in b_speaker else WHITE), (dialog_x + int(40 * scale_factor), dialog_y + int(15 * scale_factor)))
            
            # 자동 줄바꿈 및 '대처하기 어려운 일' 빨간색 하이라이트 시스템
            max_text_width = dialog_w - int(80 * scale_factor)
            lines, raw_sections = [], boss_call_current_text.split('\n')
            for s in raw_sections:
                curr_line = ""
                for char in s:
                    if dialog_font.size(curr_line + char)[0] < max_text_width: curr_line += char
                    else: lines.append(curr_line); curr_line = char
                if curr_line: lines.append(curr_line)

            for idx, line in enumerate(lines):
                y_offset = dialog_y + int(60 * scale_factor) + idx * int(45 * scale_factor)
                x_offset = dialog_x + int(40 * scale_factor)
                
                if "'대처하기 어려운 일'" in line:
                    start_k = line.find("'대처하기 어려운 일'")
                    end_k = start_k + len("'대처하기 어려운 일'")
                    screen.blit(dialog_font.render(line[0:start_k], True, WHITE), (x_offset, y_offset))
                    x_offset += dialog_font.size(line[0:start_k])[0]
                    screen.blit(dialog_font.render(line[start_k:end_k], True, RED), (x_offset, y_offset))
                    x_offset += dialog_font.size(line[start_k:end_k])[0]
                    screen.blit(dialog_font.render(line[end_k:], True, WHITE), (x_offset, y_offset))
                else:
                    screen.blit(dialog_font.render(line, True, WHITE), (x_offset, y_offset))

    # --- 담배 진열대 화면 (독립 블록 격리 및 들여쓰기 수정) ---
    elif state == "SHELF_VIEW":
        shelf_path = r"C:\Users\HOSEO\Desktop\project\world\map\good_night_store_STORY_MAP3.png"
        if os.path.exists(shelf_path):
            shelf_img = pygame.image.load(shelf_path).convert()
            shelf_img = pygame.transform.scale(shelf_img, (WIDTH, HEIGHT))
            screen.blit(shelf_img, (0, 0))

        back_rect = pygame.Rect(WIDTH//2 - 180, HEIGHT - 140, 360, 80)
        pygame.draw.rect(screen, (20,20,20), back_rect, border_radius=12)
        pygame.draw.rect(screen, WHITE, back_rect, 3, border_radius=12)

        draw_text_center(
            "카운터로 돌아가기",
            dialog_font,
            WHITE,
            back_rect.centerx,
            back_rect.centery
        )

    # --- 숨기 화면 (독립 블록 격리 및 들여쓰기 수정) ---
    elif state == "HIDING":
        hide_path = r"C:\Users\HOSEO\Desktop\project\world\map\good_night_store_STORY_MAP4.png"
        if os.path.exists(hide_path):
            hide_img = pygame.image.load(hide_path).convert()
            hide_img = pygame.transform.scale(hide_img, (WIDTH, HEIGHT))
            screen.blit(hide_img, (0, 0))

        back_rect = pygame.Rect(WIDTH//2 - 180, HEIGHT - 140, 360, 80)
        pygame.draw.rect(screen, (20,20,20), back_rect, border_radius=12)
        pygame.draw.rect(screen, WHITE, back_rect, 3, border_radius=12)

        draw_text_center(
            "카운터로 돌아가기",
            dialog_font,
            WHITE,
            back_rect.centerx,
            back_rect.centery
        )
    
    # --- [상태 6] 게임 시작 페이드 아웃 전환 ---
    elif state == "FADE_OUT":
        if cap.isOpened():
            ret, frame = cap.read()
            if not ret: cap.set(cv2.CAP_PROP_POS_FRAMES, 0); ret, frame = cap.read()
            if ret:
                frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB); frame = cv2.resize(frame, (WIDTH, HEIGHT))
                screen.blit(pygame.image.frombuffer(frame.tobytes(), (WIDTH, HEIGHT), "RGB"), (0, 0))

        fade_surface = pygame.Surface((WIDTH, HEIGHT))
        fade_surface.fill((0, 0, 0))
        fade_surface.set_alpha(fade_alpha)
        screen.blit(fade_surface, (0, 0))
        
        fade_alpha += 8 
        if fade_alpha >= 255:
            if bell_sound:
                bell_channel = bell_sound.play()
                while bell_channel and bell_channel.get_busy():
                    for ev in pygame.event.get():
                        if ev.type == pygame.QUIT: pygame.quit(); sys.exit()
                    clock.tick(30)
            state = "STORY"
            story_index = 0
            char_index = 0
            pause_timer = 0
            if os.path.exists(PATH_BGM):
                pygame.mixer.music.set_volume(0.0)
                pygame.mixer.music.play(-1)

    # 화면 업데이트
    pygame.display.flip() 
    clock.tick(60)

