CHOSUNG = ['ㄱ', 'ㄲ', 'ㄴ', 'ㄷ', 'ㄸ', 'ㄹ', 'ㅁ', 'ㅂ', 'ㅃ', 'ㅅ', 'ㅆ', 'ㅇ', 'ㅈ', 'ㅉ', 'ㅊ', 'ㅋ', 'ㅌ', 'ㅍ', 'ㅎ']
JOUNGSUNG = ['ㅏ', 'ㅐ', 'ㅑ', 'ㅒ', 'ㅓ', 'ㅔ', 'ㅕ', 'ㅖ', 'ㅗ', 'ㅘ', 'ㅙ', 'ㅚ', 'ㅛ', 'ㅜ', 'ㅝ', 'ㅞ', 'ㅟ', 'ㅠ', 'ㅡ', 'ㅢ', 'ㅣ']
JONGSUNG = ['', 'ㄱ', 'ㄲ', 'ㄳ', 'ㄴ', 'ㄵ', 'ㄶ', 'ㄷ', 'ㄹ', 'ㄺ', 'ㄻ', 'ㄼ', 'ㄽ', 'ㄾ', 'ㄿ', 'ㅀ', 'ㅁ', 'ㅂ', 'ㅄ', 'ㅅ', 'ㅆ', 'ㅇ', 'ㅈ', 'ㅊ', 'ㅋ', 'ㅌ', 'ㅍ', 'ㅎ']
COMPLEX_VOWELS = {('ㅗ', 'ㅏ'): 'ㅘ', ('ㅗ', 'ㅐ'): 'ㅙ', ('ㅗ', 'ㅣ'): 'ㅚ', ('ㅜ', 'ㅓ'): 'ㅝ', ('ㅜ', 'ㅔ'): 'ㅞ', ('ㅜ', 'ㅣ'): 'ㅟ', ('ㅡ', 'ㅣ'): 'ㅢ'}
COMPLEX_CONJS = {('ㄱ', 'ㅅ'): 'ㄳ', ('ㄴ', 'ㅈ'): 'ㄵ', ('ㄴ', 'ㅎ'): 'ㄶ', ('ㄹ', 'ㄱ'): 'ㄺ', ('ㄹ', 'ㅁ'): 'ㄻ', ('ㄹ', 'ㅂ'): 'ㄼ', ('ㄹ', 'ㅅ'): 'ㄽ', ('ㄹ', 'ㅌ'): 'ㄾ', ('ㄹ', 'ㅍ'): 'ㄿ', ('ㄹ', 'ㅎ'): 'ㅀ', ('ㅂ', 'ㅅ'): 'ㅄ'}

class KoreanInputEngine:
    def __init__(self):
        self.history = []  
    def add_code(self, char):
        self.history.append(char)
    def backspace(self):
        if self.history: self.history.pop()
    def get_text(self):
        result = ""
        state = 0 
        cho, jung, jong = -1, -1, -1
        last_v, last_j = "", ""
        for c in self.history:
            if c in CHOSUNG and state != 2:  
                if state == 0: cho = CHOSUNG.index(c); state = 1
                elif state == 1: result += CHOSUNG[cho]; cho = CHOSUNG.index(c)
                elif state == 3: jong = JONGSUNG.index(c); last_j = c; state = 4
                elif state == 4: 
                    if (last_j, c) in COMPLEX_CONJS:
                        combined = COMPLEX_CONJS[(last_j, c)]
                        jong = JONGSUNG.index(combined); last_j = combined
                    else: 
                        result += chr(0xAC00 + cho * 588 + jung * 28 + jong)
                        cho = CHOSUNG.index(c); jung, jong = -1, -1; state = 1
            elif c in JOUNGSUNG: 
                if state == 0: result += c
                elif state == 1: jung = JOUNGSUNG.index(c); last_v = c; state = 3
                elif state == 3: 
                    if (last_v, c) in COMPLEX_VOWELS:
                        combined = COMPLEX_VOWELS[(last_v, c)]
                        jung = JOUNGSUNG.index(combined); last_v = combined
                    else:
                        result += chr(0xAC00 + cho * 588 + jung * 28); result += c
                        state = 0; cho, jung = -1, -1
                elif state == 4: 
                    found_split = False
                    for (j1, j2), comb in COMPLEX_CONJS.items():
                        if JONGSUNG.index(comb) == jong:
                            result += chr(0xAC00 + cho * 588 + jung * 28 + JONGSUNG.index(j1))
                            cho = CHOSUNG.index(j2); jung = JOUNGSUNG.index(c); last_v = c; jong = -1; state = 3
                            found_split = True; break
                    if not found_split:
                        single_j = JONGSUNG[jong]
                        result += chr(0xAC00 + cho * 588 + jung * 28)
                        cho = CHOSUNG.index(single_j); jung = JOUNGSUNG.index(c); last_v = c; jong = -1; state = 3
            else: 
                if state == 1: result += CHOSUNG[cho]
                elif state == 3: result += chr(0xAC00 + cho * 588 + jung * 28)
                elif state == 4: result += chr(0xAC00 + cho * 588 + jung * 28 + jong)
                result += c; state = 0; cho, jung, jong = -1, -1, -1
        
        if state == 1: result += CHOSUNG[cho]
        elif state == 3: result += chr(0xAC00 + cho * 588 + jung * 28)
        elif state == 4: result += chr(0xAC00 + cho * 588 + jung * 28 + jong)
        return result

